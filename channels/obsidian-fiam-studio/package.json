{
  "name": "fiam-studio-obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Fiam Studio workflow plugin for an Obsidian vault.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "install:studio": "npm run build && node scripts/install.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "obsidian": "^1.9.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "foliate-js": "^1.0.1"
  }
}
