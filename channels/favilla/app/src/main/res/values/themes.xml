<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Favilla" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/plum</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">@color/plum_wash</item>
        <item name="colorOnPrimaryContainer">@color/plum_deep</item>
        <item name="colorSecondary">@color/sage</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">@color/paper</item>
        <item name="colorSurfaceVariant">@color/paper_card</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorOnSurfaceVariant">@color/ink_muted</item>
        <item name="colorOutline">@color/paper_divider</item>
        <item name="colorOutlineVariant">@color/paper_divider</item>
        <item name="android:colorBackground">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="materialButtonStyle">@style/Widget.Favilla.Button</item>
        <item name="textInputStyle">@style/Widget.Favilla.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.Favilla.BottomNav</item>
        <item name="android:fontFamily">@font/anthropic_sans</item>
        <item name="fontFamily">@font/anthropic_sans</item>
        <!-- force Material3 widgets to use our TextAppearance.Favilla.* (Anthropic Sans EN, system CJK fallback) -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Favilla.Display</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Favilla.Display</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.Favilla.Display</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Favilla.Display</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Favilla.Display</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Favilla.Title</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Favilla.Title</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Favilla.Title</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Favilla.Title</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Favilla.Body</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Favilla.Body</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Favilla.Body</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Favilla.Body</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Favilla.Body</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Favilla.Meta</item>
    </style>

    <style name="Theme.Favilla.Transparent" parent="Theme.Favilla">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.Favilla.Splash" parent="Theme.Favilla">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <style name="Widget.Favilla.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.Favilla.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.Favilla.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.Favilla.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxStrokeColor">@color/paper_divider</item>
        <item name="hintTextColor">@color/ink_muted</item>
    </style>

    <style name="Widget.Favilla.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item</item>
        <item name="itemTextColor">@color/bottom_nav_item</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Favilla.BottomNav.Indicator</item>
        <item name="elevation">0dp</item>
        <item name="android:background">@color/nav_bar</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Favilla.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/plum_wash</item>
    </style>

    <style name="TextAppearance.Favilla.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:fontFamily">@font/anthropic_serif_italic</item>
        <item name="fontFamily">@font/anthropic_serif_italic</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Favilla.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:fontFamily">@font/anthropic_serif_italic</item>
        <item name="fontFamily">@font/anthropic_serif_italic</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Favilla.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:fontFamily">@font/anthropic_sans</item>
        <item name="fontFamily">@font/anthropic_sans</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- assistant bubble: Source Han Serif SC (思源宋体), covers CJK + Latin -->
    <style name="TextAppearance.Favilla.Chat.Assistant" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/bubble_assistant_text</item>
        <item name="android:textSize">@dimen/text_chat</item>
        <item name="android:fontFamily">@font/noto_serif_sc</item>
        <item name="fontFamily">@font/noto_serif_sc</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.Favilla.Chat.User" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/bubble_user_text</item>
        <item name="android:textSize">@dimen/text_chat</item>
        <item name="android:fontFamily">@font/anthropic_sans</item>
        <item name="fontFamily">@font/anthropic_sans</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.Favilla.Meta" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/ink_faint</item>
        <item name="android:textSize">@dimen/text_meta</item>
        <item name="android:fontFamily">@font/anthropic_mono</item>
        <item name="fontFamily">@font/anthropic_mono</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.Favilla.Metric" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">@dimen/text_metric</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
