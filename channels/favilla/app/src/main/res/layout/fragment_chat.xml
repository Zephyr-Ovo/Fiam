<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_20"
        android:paddingVertical="@dimen/space_16"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_spark"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_12"
            android:paddingEnd="@dimen/space_12">

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chat_title"
                android:textAppearance="@style/TextAppearance.Favilla.Title" />

            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chat_subtitle_cc"
                android:textAppearance="@style/TextAppearance.Favilla.Meta" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNew"
            style="@style/Widget.Favilla.Button.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="36dp"
            android:paddingHorizontal="@dimen/space_16"
            android:text="@string/chat_new"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/paper_divider"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_16"
        android:paddingBottom="@dimen/space_16"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/composer" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/space_32"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/composer">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_spark"
            android:alpha="0.85"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_16"
            android:text="@string/chat_empty_title"
            android:textAppearance="@style/TextAppearance.Favilla.Title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_4"
            android:text="@string/chat_empty_subtitle"
            android:textAppearance="@style/TextAppearance.Favilla.Body"
            android:textColor="@color/ink_muted"
            android:gravity="center" />
    </LinearLayout>

    <!-- Composer -->
    <LinearLayout
        android:id="@+id/composer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/paper"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_16"
        android:paddingTop="@dimen/space_8"
        android:paddingBottom="@dimen/space_12"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="@dimen/space_8"
            android:background="@color/paper_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_8"
            android:paddingVertical="@dimen/space_4">

            <ImageButton
                android:id="@+id/btnAttach"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/chat_attach"
                android:src="@drawable/ic_attach" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/chat_input_hint"
                android:importantForAutofill="no"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="6"
                android:minHeight="44dp"
                android:paddingHorizontal="@dimen/space_8"
                android:textColor="@color/ink"
                android:textColorHint="@color/ink_faint"
                android:textSize="@dimen/text_chat" />

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/chat_mic"
                android:src="@drawable/ic_mic" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="@dimen/space_4"
                android:background="@drawable/bg_send_button"
                android:contentDescription="@string/chat_send"
                android:src="@drawable/ic_send" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
