<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- Greeting row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/homeGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Favilla.Display"
                android:textColor="@color/ink_strong"
                tools:text="Good morning, Favilla" />

            <TextView
                android:id="@+id/homeEditToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/home_edit"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:textColor="@color/plum" />
        </LinearLayout>

        <TextView
            android:id="@+id/homeTodayNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Favilla.Meta"
            android:textColor="@color/ink_faint"
            tools:text="Today · Wed, Apr 28 · 12 thoughts" />

        <!-- Hero card -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_hero_plum"
            android:minHeight="180dp"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#33FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="ambient"
                    android:textAppearance="@style/TextAppearance.Favilla.Meta"
                    android:textColor="@color/plum_deep" />

                <TextView
                    android:id="@+id/heroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/home_hero_title"
                    android:textAppearance="@style/TextAppearance.Favilla.Display"
                    android:textColor="@color/plum_deep"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/home_hero_sub"
                    android:textAppearance="@style/TextAppearance.Favilla.Body"
                    android:textColor="@color/ink_muted" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/heroCta"
                    style="?attr/materialButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/home_hero_cta"
                    app:backgroundTint="@color/plum"
                    app:cornerRadius="999dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Quick access header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:text="@string/home_quick_title"
            android:textAppearance="@style/TextAppearance.Favilla.Title"
            android:textSize="18sp" />

        <!-- Quick access grid (rows of 2 + add tile, populated in code) -->
        <LinearLayout
            android:id="@+id/quickGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
