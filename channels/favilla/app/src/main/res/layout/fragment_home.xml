<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- Greeting row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/homeGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Favilla.Display"
                android:textColor="@color/ink_strong"
                tools:text="Good morning, Favilla" />

            <TextView
                android:id="@+id/homeEditToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/home_edit"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:textColor="@color/plum" />
        </LinearLayout>

        <TextView
            android:id="@+id/homeTodayNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Favilla.Meta"
            android:textColor="@color/ink_faint"
            tools:text="Today · Wed, Apr 28 · 12 thoughts" />

        <!-- Ambient mood strip (3 thin bands, time-of-day tint) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/plum_mist" />

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@color/plum_wash" />

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@color/accent_home_hero" />
        </LinearLayout>

        <!-- "Last thought" card (replaces walk-hero) -->
        <LinearLayout
            android:id="@+id/homeThoughtCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_tile_plum"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_thought_label"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:textColor="@color/plum" />

            <TextView
                android:id="@+id/homeThoughtBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/home_thought_empty"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_strong"
                android:textSize="15sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/homeThoughtMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/home_thought_meta"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:textColor="@color/ink_faint" />
        </LinearLayout>

        <!-- Quick access header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:text="@string/home_quick_title"
            android:textAppearance="@style/TextAppearance.Favilla.Title"
            android:textSize="18sp" />

        <!-- Quick access grid (rows of 2 + add tile, populated in code) -->
        <LinearLayout
            android:id="@+id/quickGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
