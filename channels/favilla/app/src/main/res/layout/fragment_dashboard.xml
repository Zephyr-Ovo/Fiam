<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dash_section_no"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:textColor="@color/plum_soft"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dash_title"
                android:textAppearance="@style/TextAppearance.Favilla.Display"
                android:textColor="@color/ink_strong" />

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_plum_wash" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/dash_today"
            android:textAppearance="@style/TextAppearance.Favilla.Meta"
            android:textColor="@color/ink_faint" />

        <TextView
            android:id="@+id/dashTodayDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Favilla.Title"
            android:textColor="@color/ink_strong"
            android:textSize="16sp"
            tools:text="May 22, Wed" />

        <!-- Weekday emoji strip -->
        <LinearLayout
            android:id="@+id/dashWeekStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal" />

        <!-- Encouragement banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_banner_cream"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨"
                android:textSize="22sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dash_banner"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_strong" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="22sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Focus + Streak row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tile_plum"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dash_focus_title"
                    android:textAppearance="@style/TextAppearance.Favilla.Meta"
                    android:textColor="@color/plum_deep" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/dash_focus_value"
                    android:textAppearance="@style/TextAppearance.Favilla.Display"
                    android:textColor="@color/ink_strong"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/dash_focus_delta"
                    android:textAppearance="@style/TextAppearance.Favilla.Meta"
                    android:textColor="@color/plum" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tile_cream"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dash_streak_title"
                    android:textAppearance="@style/TextAppearance.Favilla.Meta"
                    android:textColor="@color/ink_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/dash_streak_value"
                    android:textAppearance="@style/TextAppearance.Favilla.Display"
                    android:textColor="@color/ink_strong"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="🔥 keep it up"
                    android:textAppearance="@style/TextAppearance.Favilla.Meta"
                    android:textColor="@color/ink_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- Health Overview -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:background="@drawable/bg_health_ring">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dash_health_score"
                            android:textAppearance="@style/TextAppearance.Favilla.Display"
                            android:textColor="@color/plum_deep"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dash_health_label"
                            android:textAppearance="@style/TextAppearance.Favilla.Meta"
                            android:textColor="@color/plum" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="18dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dash_health_title"
                        android:textAppearance="@style/TextAppearance.Favilla.Title"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❤ HR"
                                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                                android:textColor="@color/ink_faint" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dash_health_hr"
                                android:textAppearance="@style/TextAppearance.Favilla.Body"
                                android:textColor="@color/ink_strong"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="○ O₂"
                                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                                android:textColor="@color/ink_faint" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dash_health_o2"
                                android:textAppearance="@style/TextAppearance.Favilla.Body"
                                android:textColor="@color/ink_strong"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌙 sleep"
                                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                                android:textColor="@color/ink_faint" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dash_health_sleep"
                                android:textAppearance="@style/TextAppearance.Favilla.Body"
                                android:textColor="@color/ink_strong"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👣 steps"
                                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                                android:textColor="@color/ink_faint" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dash_health_steps"
                                android:textAppearance="@style/TextAppearance.Favilla.Body"
                                android:textColor="@color/ink_strong"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Upcoming Events -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"
            android:text="@string/dash_events_title"
            android:textAppearance="@style/TextAppearance.Favilla.Title"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="6dp">

            <include layout="@layout/item_dash_event"
                android:id="@+id/dashEv1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/paper_divider"
                android:layout_marginStart="56dp"
                android:layout_marginEnd="16dp" />

            <include layout="@layout/item_dash_event"
                android:id="@+id/dashEv2" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
