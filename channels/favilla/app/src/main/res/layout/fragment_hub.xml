<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_20">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hub_title"
            android:textAppearance="@style/TextAppearance.Favilla.Display" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/space_4"
            android:paddingBottom="@dimen/space_24"
            android:text="@string/tagline"
            android:textAppearance="@style/TextAppearance.Favilla.Meta" />

        <!-- AI control card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="@dimen/space_12"
                    android:src="@drawable/ic_robotic_arm"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hub_section_ai"
                    android:textAppearance="@style/TextAppearance.Favilla.Title" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_4"
                android:paddingBottom="@dimen/space_12"
                android:text="@string/hub_ai_hint"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_muted" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swAiControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hub_ai_toggle"
                android:textAppearance="@style/TextAppearance.Favilla.Body" />

            <TextView
                android:id="@+id/tvAiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_8"
                android:textAppearance="@style/TextAppearance.Favilla.Meta"
                android:text="bridge: idle" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="@dimen/space_16" />

        <!-- Voice card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_section_voice"
                android:textAppearance="@style/TextAppearance.Favilla.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_4"
                android:paddingBottom="@dimen/space_16"
                android:text="@string/hub_voice_hint"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_muted" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoice"
                    style="@style/Widget.Favilla.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="@dimen/space_32"
                    android:text="Hold to talk"
                    app:icon="@drawable/ic_mic"
                    app:iconGravity="textStart" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvVoiceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="@dimen/space_12"
                android:textAppearance="@style/TextAppearance.Favilla.Meta" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="@dimen/space_16" />

        <!-- Stickers card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_section_stickers"
                android:textAppearance="@style/TextAppearance.Favilla.Title" />

            <TextView
                android:id="@+id/tvStickersEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_8"
                android:text="@string/hub_no_stickers"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_muted" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStickers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_12"
                android:visibility="gone" />
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="@dimen/space_16" />

        <!-- Images card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_section_images"
                android:textAppearance="@style/TextAppearance.Favilla.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/space_4"
                android:paddingBottom="@dimen/space_12"
                android:text="@string/hub_no_images"
                android:textAppearance="@style/TextAppearance.Favilla.Body"
                android:textColor="@color/ink_muted" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickImage"
                style="@style/Widget.Favilla.Button.Tonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hub_pick_image"
                app:icon="@drawable/ic_attach"
                app:iconGravity="textStart" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
