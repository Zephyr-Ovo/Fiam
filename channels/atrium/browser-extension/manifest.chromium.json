{
  "manifest_version": 3,
  "name": "Fiam Browser Bridge",
  "version": "0.1.0",
  "description": "Give Fiam compact page context and controlled browser actions.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8766/*", "http://localhost:8766/*", "https://fiet.cc/*"],
  "action": {
    "default_title": "Fiam Browser Bridge",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}