{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atrium",
  "version": "0.1.0",
  "identifier": "cc.fiam.atrium",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atrium",
        "width": 1120,
        "height": 760,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
